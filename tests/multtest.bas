10 REM Integer multiplication self-test (sectioned)
20 REM Only prints failures, or final success message
30 fail%=0
40 RESTORE 1000
50 READ tag$
60 IF tag$="END" THEN GOTO 900
70 PRINT
80 PRINT "Testing ";tag$
90 GOSUB 200
100 GOTO 50

200 REM Run tests in current section
210 READ a$
220 IF a$="ENDSEC" THEN RETURN
230 READ b$,e$
240 a=VAL(a$)
250 b=VAL(b$)
260 expected=VAL(e$)
270 result=a*b
280 IF result<>expected THEN GOSUB 500
290 GOTO 210

500 PRINT "FAIL: ";a$;" * ";b$;" expected ";e$;" got ";result
510 fail%=fail%+1
520 RETURN

900 IF fail%=0 THEN PRINT "All integer multiplication tests passed"
910 END

