20 PRINT "3x3 * (3xN) MATRIX TEST"
30 INPUT "ENTER N (<=50) ";N%
40 IF N%<1 OR N%>50 THEN PRINT "OUT OF RANGE":END
50 DIM A(2,2),B(2,N%-1),C(2,N%-1)
60 PRINT : PRINT "ENTER 3x3 MATRIX A"
70 FOR I%=0 TO 2
80 FOR J%=0 TO 2
90 A(I%,J%) = 2
100 NEXT J%
110 NEXT I%
120 PRINT : PRINT "ENTER 2xN MATRIX B"
130 FOR I%=0 TO 2
140 FOR J%=0 TO N%-1
150 B(I%,J%) = 2
160 NEXT J%
170 NEXT I%
180 REM MULTIPLY: C = A * B
190 FOR I%=0 TO 2
200 FOR J%=0 TO N%-1
210 C(I%,J%)=0
220 FOR K%=0 TO 2
230 C(I%,J%)=C(I%,J%)+A(I%,K%)*B(K%,J%)
240 NEXT K%
250 NEXT J%
260 NEXT I%
270 PRINT : PRINT "RESULT (2x";N%;")"
280 FOR I%=0 TO 2
290 FOR J%=0 TO N%-1
300 PRINT LEFT$(STR$(C(I%,J%))+"        ",8);
310 NEXT J%
320 PRINT
330 NEXT I%
340 END
