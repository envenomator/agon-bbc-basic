   10 MODE 0
   20 N%=10
   30 DIM A(2,2), B(2,2), C(2,2), R(2,2), P(2,N%-1), Q(2,N%-1)
   40
   50 A() = 1.0, 0.1, 0.2, 0.0, 0.9, -0.3, 0.1, 0.2, 0.8
   60 B() = 0.8, 0.0, 0.3, 0.0, 1.0, 0.0, -0.2, 0.0, 0.9
   70 C() = 0.95, -0.15, 0.0, 0.15, 0.95, 0.0, 0.0, 0.0, 1.0
   80
   90 FOR J%=0 TO N%-1
  100   X = J%/10 + 0.1
  110   Y = J%/7 + 0.2
  120   P(0,J%) = X
  130   P(1,J%) = Y - 0.5
  140   P(2,J%) = ABS(X - Y) / 3
  150 NEXT
  160
  170 R() = B() . A()
  180 R() = C() . R()
  190 Q() = R() . P()
  200
  210 FOR I%=0 TO 2
  220   PRINT "Q(";I%;",0..";N%-1;") = ";
  230   FOR J%=0 TO N%-1
  240     PRINT Q(I%,J%);" ";
  250   NEXT
  260   PRINT
  270 NEXT
  280 END
